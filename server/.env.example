# Claude.ai Relay Configuration
# Copy this file to server/.env and replace placeholders with real values.

# Required by relay.py
CLAUDEAI_SESSION=your_claude_session_key_here
LASTACTIVE_ORG=your_last_active_org_uuid_here
RELAY_PORT=8765

# Optional fields (used by some local POC scripts/tools)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CF_CLEARANCE=your_cf_clearance_cookie_here
CF_BM=your_cf_bm_cookie_here
SSID=your_session_id_here
ANTHROPIC_DEVICE_ID=your_anthropic_device_id_here

# Raspberry Pi deployment scripts
RPI_HOST=YOUR_RPI_USER@YOUR_RPI_IP
RPI_DIR=/home/pi/claude-relay
